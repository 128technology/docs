{
  "mcpServers": {
    "atlassian-release-notes": {
      "command": "node",
      "args": [
        "src/server.js"
      ],
      "cwd": "./tools/atlassian-rovo-release-notes-mcp",
      "env": {
        "ATLASSIAN_MCP_ENDPOINT": "https://mcp.atlassian.com/v1/mcp",
        "ATLASSIAN_BEARER_TOKEN": "replace-with-oauth-bearer-token"
      }
    }
  }
}